# OpenIntern backend env template (from README)

# Server
DATABASE_URL=postgres://user:pass@127.0.0.1:5432/openintern
PORT=3000
DATA_DIR=data

# LLM
LLM_PROVIDER=openai
LLM_MODEL=
LLM_API_KEY=
OPENAI_API_KEY=sk-ant-oat01-f1whoQco7RCqxSQU6ntmvNKS7UFyZ9UDF6-2MOEWMM9pA_pZwALIybcov6Ww89zvdoxzHUocJl85a3KZaDMss14B4IMrtAA
OPENAI_BASE_URL=https://code.newcli.com/codex/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=

# Embedding
EMBEDDING_PROVIDER=hash

# Feishu
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_POLL_INTERVAL_MS=120000

# MinerU
MINERU_ENABLED=false
MINERU_API_KEY=
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_POLL_INTERVAL_MS=3000
MINERU_MAX_POLL_ATTEMPTS=120
MINERU_DEFAULT_MODEL_VERSION=pipeline

# CLI runtime context
AGENT_API_URL=http://localhost:3000
AGENT_ORG_ID=org_default
AGENT_USER_ID=user_default
AGENT_PROJECT_ID=
